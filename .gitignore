# Node
**/node_modules/
node_modules/

# Fichiers .env : non exclus — versionnés pour staging / clone aligné.

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Runtime / temp
tmp/
temp/
*.pid
*.seed

# Uploads and generated media (contenu ignoré, .gitkeep versionnés pour créer les dossiers)
# Chaque sous-projet gère son propre .gitignore pour uploads/
public/uploads/

# Build / coverage
coverage/
dist/
build/

# OS / editor
.DS_Store
.vscode/
.idea/

# Docker Compose interpolation (secrets — garder les *.example versionnés)
**/docker-compose.production.env
**/docker-compose.staging.env

# Sauvegardes compose locales
**/*.bak.*

# Staging uploads (même logique que uploads/) — on ignore le contenu mais on garde les .gitkeep
**/uploads-staging/**
!**/.gitkeep
