NODE_ENV=development
PORT=7005

DB_USERNAME=c
DB_PASSWORD=CppEurope@2025!
DB_HOST=presselocale-db
DB_PORT=3306
DB_DIALECT=mariadb
DB_NAME_USER_DEV=presse_locale_prod_cppeurope_v1
DB_NAME=presse_locale_prod_cppeurope_v1

# Doit être identique au user-backend qui signe les tokens.
# Run local (sans Docker) + user-backend dev → dev_* ci-dessous.
# presseLocale en Docker (docker-compose.dev.yml) : JWT surchargés pour coller à user-backend/.env.production (compose hostinger « prod » sur 7001).
JWT_REFRESH_SECRET=dev_refresh_secret
JWT_SIGN_SECRET=dev_sign_secret
EXPIRE_EXTEND_SESSION=30m
EXPIRE_SESSION=30m

REACT_APP_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8082,http://127.0.0.1:8082
MEDIA_BACKEND_URL=http://localhost:7004/api/media/getMedia
MEDIA_LOCALE_BACKEND_URL=http://localhost:7008/api/media-locale/getMedia
