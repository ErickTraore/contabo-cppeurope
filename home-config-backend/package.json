{
  "name": "home-config-backend",
  "version": "1.0.0",
  "private": true,
  "description": "Config page d'accueil CPPEurope (une ligne, 3 catégories). Local: npm run dev:docker. Node sur l'hôte (debug): npm run dev:docker:db-only puis npm run dev:host.",
  "main": "server.prod.js",
  "scripts": {
    "start": "NODE_ENV=production node server.prod.js",
    "dev:docker": "docker compose -f docker-compose.dev.yml up -d --build",
    "dev:docker:down": "docker compose -f docker-compose.dev.yml down",
    "dev:docker:db-only": "docker compose -f docker-compose.dev.yml up -d mariadb",
    "dev:docker:logs": "docker compose -f docker-compose.dev.yml logs -f home-config-backend",
    "dev:host": "DB_HOST=127.0.0.1 DB_PORT=3321 node server.dev.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "mariadb": "^3.4.5",
    "multer": "^2.1.1",
    "sequelize": "^6.35.2"
  },
  "type": "commonjs"
}
